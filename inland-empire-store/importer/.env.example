# Standalone importer configuration. Copy to importer/.env (gitignored).

# ----- WooCommerce REST API (target store) -----------------------------------
# Create keys: WP Admin -> WooCommerce -> Settings -> Advanced -> REST API.
# Over Tailscale point this at the host running the stack, e.g. Pi #1:
#   WC_STORE_URL=http://100.110.40.108:8080
WC_STORE_URL=http://localhost:8080
WC_CONSUMER_KEY=ck_xxx
WC_CONSUMER_SECRET=cs_xxx
WC_VERIFY_SSL=true

# ----- eBay Trading API (optional) -------------------------------------------
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_USER_TOKEN=
EBAY_ENVIRONMENT=production

# ----- Optional local AI (Pi #1 'builder' Ollama, FREE) ----------------------
# Used only to clean up descriptions / boost category confidence. Off by default.
OLLAMA_ENABLED=false
OLLAMA_URL=http://100.110.40.108:8001
OLLAMA_MODEL=llama3.2

# ----- Optional OCR (Pi #3 'ops' Tesseract, FREE) ----------------------------
# Reads model/serial numbers off product photos to fill missing specifics.
OCR_ENABLED=false

# ----- Behavior --------------------------------------------------------------
IMAGE_CACHE_DIR=cache/images
REPORT_DIR=reports
DEFAULT_STATUS=draft
PRICE_MARKUP_PERCENT=0
