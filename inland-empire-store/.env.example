# =============================================================================
# Inland Empire Electronics — Self-Hosted WooCommerce Store
# Environment configuration template.
#
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file. It is gitignored.
# =============================================================================

# ----- Site / domain ---------------------------------------------------------
# Public domain. For local development use "localhost".
SITE_DOMAIN=localhost
SITE_URL=http://localhost:8080
# Used by Let's Encrypt (production only).
LETSENCRYPT_EMAIL=admin@anstelias.com

# ----- Container platform ----------------------------------------------------
# Leave blank on x86-64 servers. On Raspberry Pi (64-bit OS) you may set:
#   linux/arm64
# All images used (wordpress, mariadb, redis, nginx, wordpress:cli) publish
# multi-arch manifests, so this is usually auto-detected and can stay blank.
DOCKER_DEFAULT_PLATFORM=

# ----- Database (MariaDB) ----------------------------------------------------
MYSQL_DATABASE=anstelias_store
MYSQL_USER=anstelias
MYSQL_PASSWORD=change_me_strong_db_password
MYSQL_ROOT_PASSWORD=change_me_strong_root_password
DB_HOST=db:3306
DB_TABLE_PREFIX=wp_

# ----- Redis -----------------------------------------------------------------
# Optional password for Redis. Leave blank to disable auth on a private network.
REDIS_PASSWORD=

# ----- WordPress admin (consumed by scripts/wp-install.sh) -------------------
WP_TITLE=Inland Empire Electronics
WP_ADMIN_USER=ie_admin
WP_ADMIN_PASSWORD=change_me_strong_admin_password
WP_ADMIN_EMAIL=admin@anstelias.com

# ----- WordPress salts -------------------------------------------------------
# Generate unique values at https://api.wordpress.org/secret-key/1.1/salt/
# or run: scripts/wp-install.sh which will inject them automatically.
WP_AUTH_KEY=
WP_SECURE_AUTH_KEY=
WP_LOGGED_IN_KEY=
WP_NONCE_KEY=
WP_AUTH_SALT=
WP_SECURE_AUTH_SALT=
WP_LOGGED_IN_SALT=
WP_NONCE_SALT=

# ----- HTTP ports (host side) ------------------------------------------------
HTTP_PORT=8080
HTTPS_PORT=8443

# ----- PHP tuning ------------------------------------------------------------
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILESIZE=128M
PHP_POST_MAX_SIZE=128M
PHP_MAX_EXECUTION_TIME=300

# ----- eBay API (optional; CSV import works without these) -------------------
# Used by the standalone Python importer and/or the WP importer API mode.
# Obtain from https://developer.ebay.com/ (free developer account).
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_USER_TOKEN=
EBAY_ENVIRONMENT=production

# ----- WooCommerce REST API (used by the standalone Python importer) ---------
# Generate in WP Admin -> WooCommerce -> Settings -> Advanced -> REST API.
WC_STORE_URL=http://localhost:8080
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
